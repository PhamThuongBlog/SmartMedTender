# Database
DATASOURCE_URL=jdbc:postgresql://postgres:5432/medbid_prod
DATASOURCE_USERNAME=medbid
DATASOURCE_PASSWORD=change-me-in-production

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Redis
REDIS_HOST=redis

# JWT
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-256-bits

# AI Providers (optional)
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=

# OCR
TESSDATA_PREFIX=/usr/share/tesseract-ocr/4.00/tessdata

# File Storage
FILE_UPLOAD_DIR=/app/uploads
BACKUP_DIR=/app/backups

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
